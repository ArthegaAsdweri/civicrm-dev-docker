# General
TZ=Europe/Berlin

# MariaDB root credentials (shared)
DB_ROOT_USER=root
DB_ROOT_PASS=rootPass
DB_ROOT_HOST=%

# Civi main DB
CIVI_DB_HOST=civicrm-db
CIVI_DB_PORT=3306
CIVI_DB_NAME=civicrm
CIVI_DB_USER=civicrm
CIVI_DB_PASS=civicrmPass

# Test DB (separate volume/container)
TEST_DB_HOST=test-db
TEST_DB_PORT=3306
TEST_DB_NAME=civicrm_test
TEST_DB_USER=civicrm
TEST_DB_PASS=civicrmPass

# phpMyAdmin
PMA_HOSTS=civicrm-db,test-db
PMA_USER="${DB_ROOT_USER}"
PMA_PASSWORD="${DB_ROOT_PASS}"